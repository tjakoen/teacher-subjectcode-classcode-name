; GRAIN ships on GitHub Packages (public, but Packages still needs auth to read).
; This file only maps the @tjakoen scope to the registry - it holds NO token.
; Local: put //npm.pkg.github.com/:_authToken=<PAT read:packages> in ~/.npmrc (never here).
; CI: deploy-scanner.yml appends that token line from ${{ secrets.GITHUB_TOKEN }} before install.
@tjakoen:registry=https://npm.pkg.github.com
